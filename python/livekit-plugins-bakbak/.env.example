# Copy to `.env` and fill in values. `.env` is gitignored.
# Load before tests: `set -a && source .env && set +a`  (bash/zsh)

BAKBAK_API_KEY=
# Optional — use a real id from: python scripts/smoke_tts.py --list-voices
# BAKBAK_VOICE_ID=
# BAKBAK_LANGUAGE=hi
# Optional — default text for scripts/smoke_tts.py (override with -t / --text)
# BAKBAK_SMOKE_TEXT=
# Optional — defaults to production hub
# BAKBAK_BASE_URL=https://hub.getraya.app
